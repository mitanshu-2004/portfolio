# Groq API Configuration — https://console.groq.com/keys
#
# Use GROQ_API_KEYS (plural) for multi-key failover. The client rotates
# round-robin across all keys; on a 429 it parks that key for the duration
# Groq tells it to wait, and the next request goes to the next key. With
# N keys you get roughly N× the per-minute throughput of the free tier.
#
# Format: comma-separated, no spaces, no quotes. In Vercel paste this
# single string into the GROQ_API_KEYS environment variable.
#
# Example with 4 keys:
# GROQ_API_KEYS=gsk_AAA...,gsk_BBB...,gsk_CCC...,gsk_DDD...
GROQ_API_KEYS=

# Single key (legacy). Used only if GROQ_API_KEYS above is empty.
# GROQ_API_KEY=gsk_your_single_api_key_here

# Contact Email (used in chat responses and fallback messages)
# This email is shown to users when the chatbot can't answer something
CONTACT_EMAIL=mitanshug2004@gmail.com

# Sentry Error Tracking (optional, but recommended for production)
# Get your DSN from: https://sentry.io/signup/
# Leave empty to disable Sentry integration (logs to console instead)
SENTRY_DSN=

# Environment
NODE_ENV=production

# Vercel specific (set automatically on Vercel)
# VERCEL=1
# VERCEL_ENV=production

