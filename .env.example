# Groq API Configuration
# Get your API keys from: https://console.groq.com/keys

# Single API Key (used if GROQ_API_KEYS is not set)
GROQ_API_KEY=gsk_your_single_api_key_here

# Multiple API Keys (optional - use this for failover)
# Format: key1,key2,key3 (comma-separated)
# When set, this takes precedence over GROQ_API_KEY
# If one API fails, automatically uses the next one
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Contact Email (used in chat responses and fallback messages)
# This email is shown to users when the chatbot can't answer something
CONTACT_EMAIL=mitanshug2004@gmail.com

# Sentry Error Tracking (optional, but recommended for production)
# Get your DSN from: https://sentry.io/signup/
# Leave empty to disable Sentry integration (logs to console instead)
SENTRY_DSN=

# Environment
NODE_ENV=production

# Vercel specific (set automatically on Vercel)
# VERCEL=1
# VERCEL_ENV=production

